# --- Required secrets --------------------------------------------------------
# Discord bot token: https://discord.com/developers/applications -> your app -> Bot -> Reset Token
DISCORD_BOT_TOKEN=your-discord-bot-token-here

# DeepSeek API key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# --- Optional overrides (defaults shown) -------------------------------------
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
COMMAND_PREFIX=!
MAX_HISTORY_TURNS=10
MAX_TOKENS=1200
COOLDOWN_SECONDS=5
# Approx DeepSeek V4 Flash pricing per 1M tokens, used only for the !usage cost estimate:
PRICE_IN_PER_M=0.14
PRICE_OUT_PER_M=0.28
# Persistent storage for memory + usage. Leave unset locally. On Railway, mount a
# Volume and set this to its mount path so state survives restarts:
# DATA_DIR=/data
# Thinking mode is OFF by default (faster, cheaper, avoids empty replies). Set "on" for deeper reasoning.
DEEPSEEK_THINKING=off
# The default personality is Young Sheldon (set in bot.py). Override it here if you like:
# SYSTEM_PROMPT=You are a helpful, concise assistant in our private Discord server.
